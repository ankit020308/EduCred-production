NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000
MONGO_URI=mongodb://127.0.0.1:27017/educred

JWT_SECRET=replace-with-64-char-random-secret
REFRESH_SECRET=replace-with-64-char-random-refresh-secret
SESSION_SECRET=replace-with-64-char-random-session-secret

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-gmail-app-password
EMAIL_FROM=EduCred <your-email@gmail.com>

GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

SEED_DEFAULT_ADMIN=true
ADMIN_EMAIL=admin@educred.local
ADMIN_PASSWORD=ChangeThisAdminPass123!
