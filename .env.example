# ─────────────────────────────────────────────────────────────────────────────
# EDUCRED: PRODUCTION ENVIRONMENT TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Populate the variables with your production/staging credentials.
# 3. DO NOT commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# --- SERVER CONFIGURATION ---
NODE_ENV=production
PORT=5001
CLIENT_URL=http://localhost:3000,https://educred.in,https://educred-frontend.vercel.app

# --- DATABASE (POSTGRESQL) ---
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/educred

# --- SECURITY & AUTHENTICATION ---
# Generate strong 64-character strings for these secrets
JWT_SECRET=your_jwt_access_secret_here
REFRESH_SECRET=your_jwt_refresh_secret_here
SESSION_SECRET=your_express_session_secret_here

# --- BLOCKCHAIN (ETHEREUM / L2) ---
# Your authoritative blockchain RPC provider
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Deployed Contract Address (EduCred.sol)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Used to encrypt sensitive university wallet private keys at rest (AES-256-GCM)
# Generate a strong 32-character encryption key
WALLET_ENCRYPTION_KEY=your_secure_aes_encryption_key_here

# --- IPFS (DECENTRALIZED STORAGE - PINATA) ---
# Used for persistent document storage
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key
PINATA_JWT=your_pinata_jwt_token

# --- EMAIL (OTP & NOTIFICATIONS) ---
# Use Resend on Render free services because outbound SMTP ports are blocked.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="EduCred Global Support <support@yourdomain.com>"

# SMTP remains supported for local development or paid hosts with SMTP egress.
# EMAIL_PROVIDER=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=notifications@yourdomain.com
# EMAIL_PASS=your_smtp_app_password

# --- GOOGLE OAUTH 2.0 (OPTIONAL) ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/auth/google/callback

# --- SYSTEM INITIALIZATION ---
# Set to 'true' on first boot to create the root administrative account
SEED_DEFAULT_ADMIN=false
ADMIN_EMAIL=admin@educred.in
ADMIN_PASSWORD=your_initial_secure_password
