# EduCred Backend Configuration
# ---------------------------------------------------------
# Copy this file to .env and provide your actual credentials.
# ---------------------------------------------------------

# 1. Server Infrastructure
PORT=5001
MONGO_URI=mongodb://localhost:27017/educred
CLIENT_URL=http://localhost:3000

# 2. Blockchain Configuration (Local Ganache/Ethereum)
# RPC URL for the blockchain node (e.g., Alchemy, Infura, or Ganache)
RPC_URL=http://127.0.0.1:8545 
# Secure Admin Wallet Private Key (Use a dedicated deployment account)
PRIVATE_KEY=0x_your_private_key_here

# 3. Security & Logic
# Secret for signing Access and Refresh Tokens
JWT_SECRET=provide_a_long_random_string_here
REFRESH_SECRET=provide_another_long_random_string_here
# System Admin Default Credentials
ADMIN_EMAIL=admin@educred.com
ADMIN_PASSWORD=admin123

# 4. Third-Party Services (EXTERNAL CREDENTIALS)
# Google OAuth (Console: https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary (Storage: https://cloudinary.com/)
CLOUDINARY_NAME=your_cloudinary_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Nodemailer (Email: e.g., Gmail App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password_here

# Twilio (SMS/OTP: https://www.twilio.com/)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
