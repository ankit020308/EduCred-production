# 🚀 EduCred: Production Environment Blueprint
# Standard configuration template for cloud-grade decentralized registries.
# Copy this to .env and populate with institutional credentials.

# ─── ARCHITECTURE ──────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
CLIENT_URL=https://educred-protocol.com

# ─── DATA LAYER (DATABASE) ──────────────────────────────────────────────────
# Primary MongoDB Atlas URI (connection pooling managed in config/db.js)
MONGO_URI=mongodb+srv://<USER>:<PASS>@<cluster>.mongodb.net/educred?retryWrites=true&w=majority

# ─── SECURITY & AUTHENTICATION ──────────────────────────────────────────────
# Generate via: openssl rand -base64 64
JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET_KEY_HERE
JWT_EXPIRES_IN=7d

# ─── CLOUD STORAGE (FILE REGISTRY) ─────────────────────────────────────────
# Obtained via Cloudinary 'Dashboard' API Settings
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── WEB3 & DECENTRALIZED LEDGER ───────────────────────────────────────────
# RPC Provider (Alchemy, Infura, or public node)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key

# Institutional Wallet Signing Key (University Account)
# WARNING: NEVER EXPOSE THIS IN CLIENT-SIDE OR GIT.
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Deployed Smart Contract Registry Address
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS_HERE

# ─── COMMUNICATION & NOTIFICATIONS ─────────────────────────────────────────
# SendGrid API Key for Authentication & Protocol Alerts
SENDGRID_API_KEY=SG.your_sendgrid_key

# Twilio Credentials for SMS-based Node Verification
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
